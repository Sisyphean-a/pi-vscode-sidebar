{
  "name": "pi-vscode-sidebar",
  "displayName": "Pi 侧边栏",
  "version": "0.0.1",
  "description": "Pi 编码助手的 VS Code 侧边栏扩展",
  "license": "MIT",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sisyphean-a/pi-vscode-sidebar.git"
  },
  "files": [
    "dist/extension.js",
    "dist/extension.js.map",
    "dist/package.json",
    "dist/webview/**",
    "assets/**",
    "bridge/**",
    "src/view/webview/styles.css",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts && node scripts/write-dist-package-json.mjs",
    "dev": "rolldown -c rolldown.config.ts -w",
    "format": "oxlint src test bridge rolldown.config.ts --fix && oxfmt src test bridge rolldown.config.ts",
    "lint": "oxlint src test bridge rolldown.config.ts && oxfmt --check src test bridge rolldown.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run test/unit test/integration",
    "pretest:e2e": "npm run build",
    "test:e2e": "tsx test/e2e/run-e2e.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "prepackage:vsix": "npm run build",
    "package:vsix": "node scripts/package-vsix.mjs",
    "release:check": "node scripts/release-check.mjs",
    "verify": "vitest run test/unit test/integration && oxlint src test bridge rolldown.config.ts && oxfmt --check src test bridge rolldown.config.ts && tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "contributes": {
    "commands": [
      {
        "command": "piSidebar.focus",
        "title": "Pi 侧边栏：聚焦对话面板"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "piSidebar",
          "title": "助手",
          "icon": "assets/logo.svg"
        }
      ]
    },
    "views": {
      "piSidebar": [
        {
          "type": "webview",
          "id": "piSidebar.main",
          "name": "对话"
        }
      ]
    },
    "configuration": {
      "title": "Pi 侧边栏",
      "properties": {
        "piSidebar.path": {
          "type": "string",
          "default": "",
          "description": "Pi 可执行文件绝对路径。留空时自动探测。"
        },
        "piSidebar.rpcTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "RPC 请求超时时间（毫秒）。"
        },
        "piSidebar.bridgeEnabled": {
          "type": "boolean",
          "default": true,
          "description": "是否为 Pi RPC 会话启用 VS Code 桥接工具。"
        },
        "piSidebar.bridgeRequestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "description": "桥接 RPC 请求超时时间（毫秒）。"
        },
        "piSidebar.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "description": "扩展日志级别。"
        }
      }
    }
  },
  "activationEvents": [
    "onView:piSidebar.main",
    "onCommand:piSidebar.focus"
  ],
  "engines": {
    "vscode": "^1.108.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.108.0",
    "@vscode/test-electron": "^2.5.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown": "^1.0.0-rc.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  },
  "packageManager": "npm@11.13.0"
}
